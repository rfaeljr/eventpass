JWT_SECRET=mude-esta-chave-secreta-em-producao-use-uma-string-longa-e-aleatoria

# ── WhatsApp (Z-API) ─────────────────────────────────────────────────────────
# Obtenha em: https://app.z-api.io
ZAPI_BASE_URL=https://api.z-api.io
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# ── Mercado Pago ─────────────────────────────────────────────────────────────
# Obtenha em: https://www.mercadopago.com.br/developers
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=

# ── Storage S3 / MinIO ───────────────────────────────────────────────────────
