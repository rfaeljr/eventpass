# ── Banco de dados ──────────────────────────────────────────────────────────
DB_USERNAME=eventpass
DB_PASSWORD=eventpass123

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ──────────────────────────────────────────────────────────────────────
