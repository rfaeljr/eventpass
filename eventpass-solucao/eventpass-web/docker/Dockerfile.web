# ══════════════════════════════════════════════════════════════
#  Stage 1 — Build React + Vite
# ══════════════════════════════════════════════════════════════
FROM node:20-alpine AS builder

WORKDIR /app

# Copia manifesto de dependências primeiro (cache layer)
COPY package.json package-lock.json* ./

# Instala dependências (usa cache se package.json não mudou)
RUN npm ci --silent

# Copia o resto do código-fonte
COPY . .

# Build de produção (gera /app/dist)
RUN npm run build

# ══════════════════════════════════════════════════════════════
#  Stage 2 — Serve com Nginx (imagem mínima ~25 MB)
# ══════════════════════════════════════════════════════════════
FROM nginx:1.27-alpine AS production

# Remove config padrão do nginx
RUN rm /etc/nginx/conf.d/default.conf

# Copia nossa configuração customizada
COPY nginx.conf /etc/nginx/conf.d/eventpass.conf

# Copia os arquivos do build para o diretório do nginx
COPY --from=builder /app/dist /usr/share/nginx/html

# Nginx abre na porta 80
EXPOSE 80

# Health check básico
HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
  CMD wget -qO- http://localhost/health || exit 1

CMD ["nginx", "-g", "daemon off;"]